# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/bitehaus
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/bitehaus

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ─── Razorpay (Payment) ───────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── Admin ────────────────────────────────────────────
ADMIN_EMAIL=admin@bitehaus.com
ADMIN_PASSWORD=Admin@123
